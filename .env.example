# Medialane Backend ENV

STARKNET_NETWORK="mainnet"
MARKETPLACE_CONTRACT_MAINNET="0x059deafbbafbf7051c315cf75a94b03c5547892bc0c6dfa36d7ac7290d4cc33a"
COLLECTION_CONTRACT_MAINNET="0x05e73b7be06d82beeb390a0e0d655f2c9e7cf519658e04f05d9c690ccc41da03"
INDEXER_START_BLOCK=6204232

ALCHEMY_RPC_URL=
VOYAGER_API_KEY=

PINATA_JWT=
PINATA_GATEWAY=

DATABASE_URL=
PORT=3000
API_SECRET_KEY=
CORS_ORIGINS=

# Same Clerk application as the frontend (medialane-io CLERK_SECRET_KEY). Required for JWT-protected routes.
CLERK_SECRET_KEY=

# Set to false to stop all background Starknet polling (saves Alchemy quota during API-only local dev).
INDEXER_ENABLED=true

# How long the mirror waits when caught up before fetching the chain tip again.
# Lower = fresher data but more Alchemy RPC usage (shares quota with frontend sync-tx, etc.).
INDEXER_POLL_INTERVAL_MS=6000
INDEXER_BLOCK_BATCH_SIZE=500

CHIPIPAY_API_KEY=
CHIPIPAY_API_URL=

LOG_LEVEL="info"
