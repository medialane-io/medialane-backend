# Medialane Backend ENV

STARKNET_NETWORK="mainnet"
MARKETPLACE_721_CONTRACT_MAINNET="0x00f8ccaae0bc811c79605974cc1dab769b9cea8877f033f8e3c17f30457caba6"
MARKETPLACE_1155_CONTRACT_MAINNET="0x02bfa521c25461a09d735889b469418608d7d92f8b26e3d37ef174a4c2e22f99"
COMMENTS_CONTRACT_ADDRESS="0x024f97eb5abe659fb650bf162b5fc16501f8f3863a7369901ce6099462e62799"
COLLECTION_721_CONTRACT_MAINNET="0x0322cb7119955e01ac778d40976eb3ba50540bb0899f812d612f9c7e63e49fd2"
COLLECTION_721_START_BLOCK=10046166
INDEXER_START_BLOCK=9196722
COMMENTS_START_BLOCK=9060000
COLLECTION_1155_CONTRACT_MAINNET=0x067064adcaaed61e17bf50ea802ea6482336126aec5b4d032b4ff8fbb5009131

ALCHEMY_RPC_URL=
# Optional private fallback RPC. Recommended public mainnet fallback:
# https://rpc.starknet.lava.build/
STARKNET_RPC_FALLBACK_URL=
VOYAGER_API_KEY=

PINATA_JWT=
PINATA_GATEWAY=

# DATABASE_URL — PostgreSQL connection string.
#   Local dev:  install Postgres (`brew install postgresql@16`) and use
#               postgresql://USER:PASS@localhost:5432/medialane_dev?schema=public
#   Prod ops:   do NOT put the Railway URL here. Use the Railway CLI instead, e.g.
#               `bun run prod:verify`, `bun run prod:migrate-status`,
#               or `railway run --service Postgres bash -c 'DATABASE_URL="$DATABASE_PUBLIC_URL" <cmd>'`
#               The Railway-internal URL (postgres.railway.internal) only resolves
#               from inside Railway; locally you need DATABASE_PUBLIC_URL.
DATABASE_URL=
PORT=3000
API_SECRET_KEY=
CORS_ORIGINS=

INDEXER_POLL_INTERVAL_MS=6000
INDEXER_BLOCK_BATCH_SIZE=500

CHIPIPAY_API_KEY=
CHIPIPAY_API_URL=

# x402 agent payments (defaults in src/config/env.ts; override per env if needed)
# STARKNET_USDC_CONTRACT defaults to Circle-native USDC.
# X402_TREASURY_ADDRESS defaults to the Creator's Fund Starknet multisig.
# STARKNET_MDLN_CONTRACT (optional) enables the MDLN credit bonus.
STARKNET_USDC_CONTRACT=
X402_TREASURY_ADDRESS=
STARKNET_MDLN_CONTRACT=

LOG_LEVEL="info"
