generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Chain {
  STARKNET
  ETHEREUM
  SOLANA
  BITCOIN
}

enum CollectionSource {
  MEDIALANE_REGISTRY
  EXTERNAL
  PARTNERSHIP
  IP_TICKET
  IP_CLUB
  GAME
}

enum ReportTargetType {
  COLLECTION
  TOKEN
  CREATOR
  COMMENT
}

enum ReportCategory {
  COPYRIGHT_PIRACY
  VIOLENCE_GRAPHIC
  HATE_SPEECH
  SCAM_FRAUD
  SPAM
  NSFW
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  HIDDEN
  DISMISSED
  RESTORED
}

enum ClaimStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum UsernameClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationMethod {
  ONCHAIN
  SIGNATURE
  MANUAL
}

model IndexerCursor {
  chain             Chain    @id
  lastBlock         BigInt
  continuationToken String?
  updatedAt         DateTime @updatedAt
}

enum OrderStatus {
  ACTIVE
  FULFILLED
  CANCELLED
  EXPIRED
  COUNTER_OFFERED
}

model Order {
  id                       String      @id @default(cuid())
  chain                    Chain       @default(STARKNET)
  orderHash                String
  offerer                  String
  // Offer item fields
  offerItemType            String
  offerToken               String
  offerIdentifier          String
  offerStartAmount         String
  offerEndAmount           String
  // Consideration item fields
  considerationItemType    String
  considerationToken       String
  considerationIdentifier  String
  considerationStartAmount String
  considerationEndAmount   String
  considerationRecipient   String
  // Time bounds
  startTime                BigInt
  endTime                  BigInt
  // Status
  status                   OrderStatus @default(ACTIVE)
  fulfiller                String?
  // On-chain provenance
  createdBlockNumber       BigInt
  createdTxHash            String
  fulfilledTxHash          String?
  cancelledTxHash          String?
  // Denormalized (filled by orchestrator)
  nftContract              String?
  nftTokenId               String?
  priceRaw                 String?
  priceFormatted           String?
  currencySymbol           String?
  parentOrderHash          String?
  counterOfferMessage      String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@unique([chain, orderHash])
  @@index([chain, offerer])
  @@index([chain, status])
  @@index([chain, nftContract, nftTokenId])
  @@index([chain, parentOrderHash])
  @@index([chain, status, nftContract])
  @@index([considerationToken])
  @@index([createdAt])
}

enum MetadataStatus {
  PENDING
  FETCHING
  FETCHED
  FAILED
}

// GIN index for full-text search: idx_token_fts on to_tsvector('english', name||description||contractAddress||tokenId)
// Created via raw migration: prisma/migrations/20260312000000_add_fts_indexes/migration.sql
model Token {
  id              String         @id @default(cuid())
  chain           Chain          @default(STARKNET)
  contractAddress String
  tokenId         String
  owner           String
  tokenUri        String?
  metadataStatus  MetadataStatus @default(PENDING)
  isHidden         Boolean          @default(false)
  name            String?
  description     String?
  image           String?
  attributes      Json?
  ipType          String?
  licenseType     String?
  commercialUse   Boolean?
  author          String?
  transfers       Transfer[]
  collection      Collection?    @relation(fields: [chain, contractAddress], references: [chain, contractAddress])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([chain, contractAddress, tokenId])
  @@index([chain, owner])
  @@index([chain, contractAddress])
  @@index([chain, metadataStatus])
  @@index([chain, ipType])
  @@index([chain, isHidden])
}

// GIN index for full-text search: idx_collection_fts on to_tsvector('english', name||contractAddress)
// Created via raw migration: prisma/migrations/20260312000000_add_fts_indexes/migration.sql
model Collection {
  id              String         @id @default(cuid())
  chain           Chain          @default(STARKNET)
  contractAddress String
  collectionId    String?
  name            String?
  symbol          String?
  description     String?
  image           String?
  baseUri         String?
  owner           String?
  metadataStatus  MetadataStatus @default(PENDING)
  startBlock      BigInt
  isKnown         Boolean        @default(false)
  isHidden         Boolean          @default(false)
  floorPrice      String?
  totalVolume     String?
  holderCount     Int            @default(0)
  totalSupply     Int            @default(0)
  tokens          Token[]
  source          CollectionSource  @default(MEDIALANE_REGISTRY)
  claimedBy       String?
  profile         CollectionProfile?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([chain, contractAddress])
  @@index([owner])
  @@index([chain, isHidden])
}

model CollectionProfile {
  id               String     @id @default(cuid())
  collection       Collection @relation(fields: [chain, contractAddress], references: [chain, contractAddress])
  contractAddress  String
  chain            Chain
  displayName      String?
  description      String?
  image            String?
  bannerImage      String?
  websiteUrl       String?
  twitterUrl       String?
  discordUrl       String?
  telegramUrl      String?
  updatedBy        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([chain, contractAddress])
}

model CreatorProfile {
  id             String   @id @default(cuid())
  walletAddress  String   @unique
  chain          Chain    @default(STARKNET)
  displayName    String?
  bio            String?
  avatarImage    String?
  bannerImage    String?
  websiteUrl     String?
  twitterUrl     String?
  discordUrl     String?
  telegramUrl    String?
  username       String?  @unique  // approved slug — set by admin on claim approval
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UsernameClaim {
  id            String              @id @default(cuid())
  username      String
  walletAddress String
  status        UsernameClaimStatus @default(PENDING)
  adminNotes    String?
  notifyEmail   String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([walletAddress])
  @@index([status])
  @@index([username])
}

model CollectionClaim {
  id                  String             @id @default(cuid())
  contractAddress     String
  chain               Chain              @default(STARKNET)
  claimantAddress     String?
  claimantEmail       String?
  status              ClaimStatus        @default(PENDING)
  verificationMethod  VerificationMethod
  notes               String?
  adminNotes          String?
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([chain, contractAddress])
  @@index([status])
  @@index([chain, claimantAddress])
}

model ClaimChallenge {
  id               String   @id @default(cuid())
  contractAddress  String
  walletAddress    String
  challenge        String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([walletAddress, contractAddress])
}

model Transfer {
  id              String   @id @default(cuid())
  chain           Chain    @default(STARKNET)
  contractAddress String
  tokenId         String
  fromAddress     String
  toAddress       String
  blockNumber     BigInt
  txHash          String
  logIndex        Int
  token           Token    @relation(fields: [chain, contractAddress, tokenId], references: [chain, contractAddress, tokenId])
  createdAt       DateTime @default(now())

  @@unique([chain, txHash, logIndex])
  @@index([chain, contractAddress, tokenId])
  @@index([chain, toAddress])
  @@index([chain, fromAddress])
}

enum TenantPlan {
  FREE
  PREMIUM
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookEventType {
  ORDER_CREATED
  ORDER_FULFILLED
  ORDER_CANCELLED
  TRANSFER
}

enum WebhookEndpointStatus {
  ACTIVE
  DISABLED
}

enum IntentType {
  CREATE_LISTING
  MAKE_OFFER
  FULFILL_ORDER
  CANCEL_ORDER
  MINT
  CREATE_COLLECTION
  COUNTER_OFFER
}

enum IntentStatus {
  PENDING
  SIGNED
  SUBMITTED
  CONFIRMED
  FAILED
  EXPIRED
}

model TransactionIntent {
  id        String       @id @default(cuid())
  chain     Chain        @default(STARKNET)
  type      IntentType
  status    IntentStatus @default(PENDING)
  requester String
  typedData Json
  calls     Json
  signature String[]
  txHash               String?
  orderHash            String?
  parentOrderHash      String?
  counterOfferMessage  String?
  expiresAt            DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([chain, requester])
  @@index([chain, status])
  @@index([expiresAt, status])
}

model Tenant {
  id        String            @id @default(cuid())
  name      String
  email     String            @unique
  plan      TenantPlan        @default(FREE)
  status    TenantStatus      @default(ACTIVE)
  apiKeys   ApiKey[]
  webhooks  WebhookEndpoint[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([plan])
}

model ApiKey {
  id                  String       @id @default(cuid())
  tenantId            String
  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  prefix              String
  keyHash             String       @unique
  label               String       @default("")
  status              ApiKeyStatus @default(ACTIVE)
  lastUsedAt          DateTime?
  monthlyRequestCount Int          @default(0)
  monthlyResetAt      DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([tenantId])
  @@index([status])
}

model WebhookEndpoint {
  id         String                @id @default(cuid())
  tenantId   String
  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  url        String
  secret     String
  events     WebhookEventType[]
  status     WebhookEndpointStatus @default(ACTIVE)
  deliveries WebhookDelivery[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([tenantId])
  @@index([status])
}

model WebhookDelivery {
  id           String           @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint  @relation(fields: [endpointId], references: [id])
  eventType    WebhookEventType
  payload      Json
  statusCode   Int?
  responseBody String?
  deliveredAt  DateTime?
  attemptCount Int              @default(0)
  isTerminal   Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([endpointId])
  @@index([eventType])
}

model Report {
  id             String           @id @default(cuid())
  chain          Chain            @default(STARKNET)
  targetType     ReportTargetType
  targetKey      String           // canonical: "TOKEN:0x<contract>:<tokenId>", "COLLECTION:0x<contract>", "CREATOR:0x<address>"
  targetContract String?
  targetTokenId  String?
  targetAddress  String?
  reporterUserId String           // Clerk user ID — trusted via platform API key
  reviewedBy     String?          // Clerk admin user ID — honor-system
  categories     ReportCategory[]
  description    String?
  status         ReportStatus     @default(PENDING)
  adminNotes     String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([targetKey, reporterUserId])
  @@index([status])
  @@index([targetType, targetKey])
  @@index([createdAt])
}

model HiddenCreator {
  chain    Chain    @default(STARKNET)
  address  String   // normalized 64-char 0x-padded hex
  hiddenAt DateTime @default(now())

  @@id([chain, address])
}


model User {
  id            String   @id @default(cuid())
  clerkUserId   String   @unique
  walletAddress String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clerkUserId])
}

model Comment {
  id              String   @id @default(cuid())
  chain           String   @default("starknet")
  contractAddress String
  tokenId         String
  author          String
  content         String
  isHidden        Boolean  @default(false)
  txHash          String?
  blockNumber     BigInt
  blockTimestamp  BigInt
  logIndex        Int
  createdAt       DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([chain, contractAddress, tokenId])
  @@index([author])
}

enum RemixOfferStatus {
  PENDING
  AUTO_PENDING
  APPROVED
  COMPLETED
  REJECTED
  EXPIRED
  SELF_MINTED
}

model RemixOffer {
  id        String           @id @default(cuid())
  status    RemixOfferStatus @default(PENDING)

  originalContract  String
  originalTokenId   String
  creatorAddress    String

  requesterAddress  String?
  message           String?

  proposedPrice     String
  proposedCurrency  String

  licenseType    String
  commercial     Boolean  @default(false)
  derivatives    Boolean  @default(true)
  royaltyPct     Int?

  approvedCollection  String?
  remixContract       String?
  remixTokenId        String?
  orderHash           String?

  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  updatedAt   DateTime  @updatedAt

  @@index([orderHash])
  @@index([originalContract, originalTokenId])
  @@index([creatorAddress])
  @@index([requesterAddress])
  @@index([status, expiresAt])
}
