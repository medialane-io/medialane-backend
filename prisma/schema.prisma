generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Chain {
  STARKNET
  ETHEREUM
  SOLANA
  BASE
  BITCOIN
}

enum TokenStandard {
  ERC721
  ERC1155
  ERC20
}

enum ReportTargetType {
  COLLECTION
  TOKEN
  CREATOR
  COMMENT
}

enum ReportCategory {
  COPYRIGHT_PIRACY
  VIOLENCE_GRAPHIC
  HATE_SPEECH
  SCAM_FRAUD
  SPAM
  NSFW
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  HIDDEN
  DISMISSED
  RESTORED
}

enum ClaimStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  REJECTED
}

enum UsernameClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationMethod {
  ONCHAIN
  SIGNATURE
  MANUAL
}

model IndexerCursor {
  chain             Chain    @id
  lastBlock         BigInt
  continuationToken String?
  updatedAt         DateTime @updatedAt
}

enum OrderStatus {
  ACTIVE
  FULFILLED
  CANCELLED
  EXPIRED
}

model Order {
  id                       String      @id @default(cuid())
  chain                    Chain       @default(STARKNET)
  orderHash                String
  offerer                  String
  // Offer item fields
  offerItemType            String
  offerToken               String
  offerIdentifier          String
  offerStartAmount         String
  offerEndAmount           String
  // Consideration item fields
  considerationItemType    String
  considerationToken       String
  considerationIdentifier  String
  considerationStartAmount String
  considerationEndAmount   String
  considerationRecipient   String
  // Time bounds
  startTime                BigInt
  endTime                  BigInt
  // Status
  status                   OrderStatus @default(ACTIVE)
  fulfiller                String?
  // On-chain provenance
  createdBlockNumber       BigInt
  createdTxHash            String
  fulfilledTxHash          String?
  cancelledTxHash          String?
  // Denormalized (filled by orchestrator)
  nftContract              String?
  nftTokenId               String?
  priceRaw                 String?
  priceFormatted           String?
  currencySymbol           String?
  parentOrderHash          String?
  counterOfferMessage      String?
  marketplaceContract      String?
  /// Stable marketplace service ID (05-service-model §V). Resolves SNIP-12
  /// domain / fulfillment / cancellation via the SDK registry. Open-ended
  /// string. `marketplaceContract` is kept as an explorer-link helper only
  /// (draft §10.1, locked) — never a behavior discriminator.
  marketplaceService       String?
  remainingAmount          String?
  fills                    OrderFill[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@unique([chain, orderHash])
  @@index([chain, offerer])
  @@index([chain, status])
  @@index([chain, nftContract, nftTokenId])
  @@index([chain, parentOrderHash])
  @@index([chain, status, nftContract])
  @@index([considerationToken])
  @@index([createdAt])
  @@index([marketplaceContract])
  @@index([marketplaceService])
}

model OrderFill {
  id              String   @id @default(cuid())
  chain           Chain    @default(STARKNET)
  orderHash       String
  order           Order    @relation(fields: [chain, orderHash], references: [chain, orderHash])
  fulfiller       String
  quantity        String   @default("1")
  remainingAmount String?
  priceRaw        String?
  priceFormatted  String?
  currencySymbol  String?
  currencyToken   String?
  nftContract     String?
  nftTokenId      String?
  txHash          String
  logIndex        Int
  blockNumber     BigInt
  createdAt       DateTime @default(now())

  @@unique([chain, orderHash, txHash, logIndex])
  @@index([chain, orderHash])
  @@index([chain, nftContract])
  @@index([chain, nftContract, nftTokenId])
  @@index([createdAt])
}

enum MetadataStatus {
  PENDING
  FETCHING
  FETCHED
  FAILED
}

// GIN index for full-text search: idx_token_fts on to_tsvector('english', name||description||contractAddress||tokenId)
// Created via raw migration: prisma/migrations/20260312000000_add_fts_indexes/migration.sql
model Token {
  id              String         @id @default(cuid())
  chain           Chain          @default(STARKNET)
  contractAddress String
  tokenId         String
  tokenUri        String?
  metadataStatus  MetadataStatus @default(PENDING)
  isHidden         Boolean          @default(false)
  name            String?
  description     String?
  image           String?
  attributes      Json?
  ipType          String?
  licenseType     String?
  commercialUse   Boolean?
  author          String?
  /// IP-Tickets only: set true when redeem_ticket is called on-chain. The
  /// token stays transferable per contract design — this flag gates access,
  /// never ownership. Always false for every other service.
  redeemed        Boolean        @default(false)
  transfers       Transfer[]
  collection      Collection?    @relation(fields: [chain, contractAddress], references: [chain, contractAddress])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([chain, contractAddress, tokenId])
  @@index([chain, contractAddress])
  @@index([chain, metadataStatus])
  @@index([chain, ipType])
  @@index([chain, isHidden])
}

// GIN index for full-text search: idx_collection_fts on to_tsvector('english', name||contractAddress)
// Created via raw migration: prisma/migrations/20260312000000_add_fts_indexes/migration.sql
model Collection {
  id              String         @id @default(cuid())
  chain           Chain          @default(STARKNET)
  contractAddress String
  collectionId    String?
  name            String?
  symbol          String?
  description     String?
  image           String?
  baseUri         String?
  owner           String?
  metadataStatus  MetadataStatus @default(PENDING)
  startBlock      BigInt
  isFeatured      Boolean        @default(false)
  isHidden         Boolean          @default(false)
  floorPrice      String?
  totalVolume     String?
  holderCount     Int            @default(0)
  totalSupply     Int            @default(0)
  tokens          Token[]
  standard        TokenStandard
  /// Stable Medialane service ID. Open-ended string; values live in the
  /// @medialane/sdk service registry. Always set — external collections
  /// use 'external-erc721' / 'external-erc1155' instead of null.
  service         String
  claimedBy       String?
  profile         CollectionProfile?
  deletedAt   DateTime?
  deletedBy   String?       // admin identifier (IP of requester)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([chain, contractAddress])
  @@index([owner])
  @@index([chain, isHidden])
  @@index([chain, service])
}

// Fungible coins (ERC-20 today; SPL/etc. later). Distinct from Collection:
// a coin is a single fungible asset — no tokenIds, no per-token rows, no Orders.
// Price/liquidity is read live from Ekubo, never stored. Storage is chosen by
// fungibility (spec 2026-06-14-coin-collection-split-design).
model Coin {
  id              String        @id @default(cuid())
  chain           Chain         @default(STARKNET)
  contractAddress String
  standard        TokenStandard @default(ERC20)
  service         String        // "creator-coin" | "external-erc20"
  name            String?
  symbol          String?
  decimals        Int           @default(18)
  totalSupply     String?       // fungible supply (decimal string) — NOT an item count
  description     String?
  image           String?
  creator         String?       // launcher/creator wallet where known (trustless: from event)
  startBlock      BigInt
  isHidden        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([chain, contractAddress])
  @@index([chain, service])
  @@index([chain, isHidden])
}

model CollectionProfile {
  id               String     @id @default(cuid())
  collection       Collection @relation(fields: [chain, contractAddress], references: [chain, contractAddress])
  contractAddress  String
  chain            Chain
  displayName      String?
  description      String?
  image            String?
  bannerImage      String?
  websiteUrl       String?
  twitterUrl       String?
  discordUrl       String?
  telegramUrl          String?
  gatedContentTitle    String?
  gatedContentUrl      String?
  gatedContentType     String?
  hasGatedContent      Boolean  @default(false)
  slug                 String?  @unique  // approved vanity slug — set by admin on claim approval
  updatedBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([chain, contractAddress])
}

model UsernameClaim {
  id            String              @id @default(cuid())
  username      String
  walletAddress String
  status        UsernameClaimStatus @default(PENDING)
  adminNotes    String?
  notifyEmail   String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([walletAddress])
  @@index([status])
  @@index([username])
}

model CollectionSlugClaim {
  id              String              @id @default(cuid())
  slug            String
  contractAddress String
  chain           Chain               @default(STARKNET)
  walletAddress   String
  status          UsernameClaimStatus @default(PENDING)
  adminNotes      String?
  notifyEmail     String?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([walletAddress])
  @@index([contractAddress])
  @@index([status])
  @@index([slug])
}

model CollectionClaim {
  id                  String             @id @default(cuid())
  contractAddress     String
  chain               Chain              @default(STARKNET)
  claimantAddress     String?
  claimantEmail       String?
  status              ClaimStatus        @default(PENDING)
  verificationMethod  VerificationMethod
  notes               String?
  adminNotes          String?
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([chain, contractAddress])
  @@index([status])
  @@index([chain, claimantAddress])
}

model ClaimChallenge {
  id               String   @id @default(cuid())
  chain            Chain    @default(STARKNET)
  contractAddress  String
  walletAddress    String
  challenge        String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([walletAddress, contractAddress])
}

model SiwsNonce {
  id            String   @id @default(cuid())
  chain         Chain    @default(STARKNET)
  walletAddress String
  nonce         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

model Transfer {
  id              String   @id @default(cuid())
  chain           Chain    @default(STARKNET)
  contractAddress String
  tokenId         String
  fromAddress     String
  toAddress       String
  amount          String   @default("1") // always "1" for ERC-721; quantity for ERC-1155
  blockNumber     BigInt
  txHash          String
  logIndex        Int
  token           Token    @relation(fields: [chain, contractAddress, tokenId], references: [chain, contractAddress, tokenId])
  createdAt       DateTime @default(now())

  @@unique([chain, txHash, logIndex])
  @@index([chain, contractAddress, tokenId])
  @@index([chain, toAddress])
  @@index([chain, fromAddress])
}

model TokenBalance {
  id              String   @id @default(cuid())
  chain           Chain    @default(STARKNET)
  contractAddress String
  tokenId         String
  owner           String
  amount          String   // decimal string; "1" for ERC-721, "N" for ERC-1155; "0" = former holder
  updatedAt       DateTime @updatedAt

  @@unique([chain, contractAddress, tokenId, owner])
  @@index([chain, owner])
  @@index([chain, contractAddress])
  @@index([chain, contractAddress, tokenId])
}

enum TenantPlan {
  FREE
  PREMIUM
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookEventType {
  ORDER_CREATED
  ORDER_FULFILLED
  ORDER_CANCELLED
  TRANSFER
}

enum WebhookEndpointStatus {
  ACTIVE
  DISABLED
}

enum IntentType {
  CREATE_LISTING
  MAKE_OFFER
  FULFILL_ORDER
  CANCEL_ORDER
  MINT
  CREATE_COLLECTION
  COUNTER_OFFER
}

enum IntentStatus {
  PENDING
  SIGNED
  SUBMITTED
  CONFIRMED
  FAILED
  EXPIRED
}

model TransactionIntent {
  id        String       @id @default(cuid())
  chain     Chain        @default(STARKNET)
  type      IntentType
  status    IntentStatus @default(PENDING)
  requester String
  tenantId  String?       // set at creation; used to scope PATCH endpoints to the creating tenant
  typedData Json
  calls     Json
  signature String[]
  txHash               String?
  orderHash            String?
  parentOrderHash      String?
  counterOfferMessage  String?
  expiresAt            DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([chain, requester])
  @@index([chain, status])
  @@index([expiresAt, status])
}

model Tenant {
  id        String            @id @default(cuid())
  name      String
  email     String            @unique
  plan      TenantPlan        @default(FREE)
  status    TenantStatus      @default(ACTIVE)
  creditBalance Int           @default(0)
  apiKeys   ApiKey[]
  webhooks  WebhookEndpoint[]
  payments  Payment[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([plan])
}

model ApiKey {
  id                  String       @id @default(cuid())
  tenantId            String?
  tenant              Tenant?      @relation(fields: [tenantId], references: [id])
  accountId           String?
  account             Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  prefix              String
  keyHash             String       @unique
  label               String       @default("")
  /// Which app this key is provisioned for. Enables per-app traffic
  /// attribution, blast-radius isolation on leak, and future capability
  /// scoping (e.g., AGENT-only keys). Nullable for legacy keys created
  /// before this column existed; new keys should always set it.
  appSource           AppSource?
  status              ApiKeyStatus @default(ACTIVE)
  lastUsedAt          DateTime?
  monthlyRequestCount Int          @default(0)
  monthlyResetAt      DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([tenantId])
  @@index([accountId])
  @@index([status])
  @@index([appSource])
}

model WebhookEndpoint {
  id         String                @id @default(cuid())
  tenantId   String?
  tenant     Tenant?               @relation(fields: [tenantId], references: [id])
  accountId  String?
  account    Account?              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     WebhookEventType[]
  status     WebhookEndpointStatus @default(ACTIVE)
  deliveries WebhookDelivery[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([tenantId])
  @@index([accountId])
  @@index([status])
}

model WebhookDelivery {
  id           String           @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint  @relation(fields: [endpointId], references: [id])
  eventType    WebhookEventType
  payload      Json
  statusCode   Int?
  responseBody String?
  deliveredAt  DateTime?
  attemptCount Int              @default(0)
  isTerminal   Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([endpointId])
  @@index([eventType])
}

model Report {
  id             String           @id @default(cuid())
  chain          Chain            @default(STARKNET)
  targetType     ReportTargetType
  targetKey      String           // canonical: "TOKEN:0x<contract>:<tokenId>", "COLLECTION:0x<contract>", "CREATOR:0x<address>"
  targetContract String?
  targetTokenId  String?
  targetAddress  String?
  reporterWallet String           // wallet address — set server-side from identityAuth
  reviewedBy     String?          // Clerk admin user ID — honor-system
  categories     ReportCategory[]
  description    String?
  status         ReportStatus     @default(PENDING)
  adminNotes     String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([targetKey, reporterWallet])
  @@index([status])
  @@index([targetType, targetKey])
  @@index([createdAt])
}

model PopAllowlist {
  id                String   @id @default(cuid())
  chain             Chain    @default(STARKNET)
  collectionAddress String
  walletAddress     String
  allowed           Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@unique([chain, collectionAddress, walletAddress])
  @@index([chain, collectionAddress])
}

model HiddenCreator {
  chain    Chain    @default(STARKNET)
  address  String   // normalized 64-char 0x-padded hex
  hiddenAt DateTime @default(now())

  @@id([chain, address])
}

model DropClaimConditions {
  id                Int      @id @default(autoincrement())
  chain             Chain    @default(STARKNET)
  collectionAddress String
  maxSupply         String                   // u256 as decimal string
  price             String   @default("0")   // wei; "0" = free mint
  paymentToken      String   @default("0x0") // ERC-20 address or 0x0 for free
  startTime         BigInt
  endTime           BigInt
  maxPerWallet      String   @default("1")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([chain, collectionAddress])
}


enum AppSource {
  MEDIALANE_STARKNET
  MEDIALANE_IO
  MEDIALANE_PORTAL
  MEDIALANE_DAO
  MEDIALANE_SDK
}

enum AccountType {
  PERSON
  AGENT
  ORGANIZATION
  PARTNER
}

enum AccountRole {
  CREATOR
  COLLECTOR
  ORGANIZATION
  AGENT
  PARTNER
}

// Billing plan + status for an Account (07-identity §III). Replaces TenantPlan/
// TenantStatus, which are dropped with the Tenant model in the cutover phase.
enum Plan {
  FREE
  PREMIUM
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

model Account {
  id        String        @id @default(cuid())
  publicId  String        @unique
  type      AccountType   @default(PERSON)
  roles     AccountRole[] @default([])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Billing/metering state — API keys + credits are platform-layer Account
  // state (07-identity §III). Collapses the former separate Tenant model.
  plan          Plan          @default(FREE)
  status        AccountStatus @default(ACTIVE)
  creditBalance Int           @default(0)

  identities Identity[]
  profile    AccountProfile?
  apiKeys    ApiKey[]
  webhooks   WebhookEndpoint[]
  payments   Payment[]

  @@index([type])
  @@index([createdAt])
}

// An identity is one way an Account is known — a wallet, a social/email login, an
// agent key. The platform never gates the format: the app supplies `scheme` (and
// optional `provider` label) for whatever it is connecting. Identity is NOT the
// account's identity — the AccountID is (07-identity §II); identities attach to it.
model Identity {
  id         String    @id @default(cuid())
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // What this identity is — free-form, app-supplied.
  scheme     String    // "wallet" | "clerk" | "privy" | "email" | "agent" | …
  provider   String?   // issuer label: "braavos" | "ready" | "clerk" | …

  // On-chain identifier (wallet / agent key): (chain, address), normalized per chain (07 §I).
  chain      Chain?
  address    String?

  // Off-chain identifier (social / email login).
  value      String?   // provider subject / external id
  email      String?   // attribute only — NEVER unique, never a merge key (07 §II)

  appSource  AppSource @default(MEDIALANE_STARKNET)
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([chain, address])
  @@unique([scheme, value])
  @@index([accountId])
  @@index([address])
  @@index([email])
  @@index([appSource])
}

model AccountProfile {
  id          String   @id @default(cuid())
  accountId   String   @unique
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  displayName String?
  bio         String?
  avatarImage String?
  bannerImage String?
  websiteUrl  String?
  twitterUrl  String?
  discordUrl  String?
  telegramUrl String?
  username    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id              String   @id @default(cuid())
  chain           Chain    @default(STARKNET)
  contractAddress String
  tokenId         String
  author          String
  content         String
  isHidden        Boolean  @default(false)
  txHash          String?
  blockNumber     BigInt
  blockTimestamp  BigInt
  logIndex        Int
  createdAt       DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([chain, contractAddress, tokenId])
  @@index([author])
}

enum RemixOfferStatus {
  PENDING
  AUTO_PENDING
  APPROVED
  COMPLETED
  REJECTED
  EXPIRED
  SELF_MINTED
}

// ── Rewards & Ranking ─────────────────────────────────────────────────────────

// 50 levels — DAO-editable via admin API
model RewardLevel {
  level       Int      @id          // 1–50
  name        String                // "Genesis", "Explorer", etc.
  xpRequired  Int                   // cumulative XP to reach this level
  badgeColor  String   @default("#6366f1")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Per-action XP weights — DAO-editable
model RewardAction {
  type         String   @id         // "mint_asset", "buy_asset", etc.
  label        String
  xp           Int
  dailyCap     Int?                  // null = unlimited
  minValueUsdc Float?               // null = no minimum
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Global multipliers — DAO-editable
model RewardMultiplier {
  id          String   @id @default(cuid())
  name        String
  description String?
  factor      Float                 // e.g. 1.5
  condition   String                // machine-readable key, e.g. "beta_tester"
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Badge catalogue — DAO-editable
model BadgeDefinition {
  id          String      @id @default(cuid())
  key         String      @unique   // "og", "sold_out", "early_believer"
  name        String
  description String
  icon        String                // lucide icon name
  color       String      @default("#6366f1")
  category    String                // "creator" | "collector" | "community"
  enabled     Boolean     @default(true)
  awards      UserBadge[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Computed score per address — rebuilt by the recompute script
model UserScore {
  address      String   @id        // normalised wallet address
  accountId    String?              // populated opportunistically when wallet resolves to an Account
  chain        Chain    @default(STARKNET)
  totalXp      Int      @default(0)
  currentLevel Int      @default(1)
  breakdown    Json                 // { mint_asset: 200, buy_asset: 150, … }
  computedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([totalXp])
  @@index([currentLevel])
  @@index([chain])
  @@index([accountId])
}

// Awarded badges per address
model UserBadge {
  id         String          @id @default(cuid())
  address    String
  accountId  String?
  badgeKey   String
  badge      BadgeDefinition @relation(fields: [badgeKey], references: [key])
  awardedAt  DateTime        @default(now())
  txHash     String?

  @@unique([address, badgeKey])
  @@index([address])
  @@index([accountId])
}

// Audit log of every point event — written during recompute and future live tracking
model PointEvent {
  id         String   @id @default(cuid())
  chain      Chain    @default(STARKNET)
  address    String
  accountId  String?
  actionType String
  xp         Int
  multiplier Float    @default(1.0)
  finalXp    Int
  txHash     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([address])
  @@index([accountId])
  @@index([actionType])
  @@index([createdAt])
  @@index([chain, address])
}

model RemixOffer {
  id        String           @id @default(cuid())
  status    RemixOfferStatus @default(PENDING)

  originalContract  String
  originalTokenId   String
  creatorAddress    String

  requesterAddress  String?
  message           String?

  proposedPrice     String
  proposedCurrency  String

  licenseType    String
  commercial     Boolean  @default(false)
  derivatives    Boolean  @default(true)
  royaltyPct     Int?

  approvedCollection  String?
  remixContract       String?
  remixTokenId        String?
  orderHash           String?

  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  updatedAt   DateTime  @updatedAt

  @@index([orderHash])
  @@index([originalContract, originalTokenId])
  @@index([creatorAddress])
  @@index([requesterAddress])
  @@index([status, expiresAt])
}

model ServiceContract {
  id              String   @id @default(cuid())
  serviceId       String
  chain           Chain
  contractAddress String
  startBlock      String
  active          Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([serviceId])
  @@index([chain, active])
}

/// x402 payment ledger — one row per settled agent payment. The unique
/// proofNonce makes a replayed payment proof throw on insert, so credits are
/// never double-granted.
model Payment {
  id             String        @id @default(cuid())
  tenantId       String?
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  accountId      String?
  account        Account?      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  scheme         String // "starknet-transfer"
  network        String // "starknet"
  asset          String // USDC contract
  amountAtomic   String // paid amount, USDC atomic units (6dp), bigint-safe string
  creditedAmount Int // credits granted (after MDLN multiplier)
  mdlnMultiplier Float         @default(1.0)
  status         PaymentStatus @default(SETTLED)
  txHash         String
  proofNonce     String        @unique
  createdAt      DateTime      @default(now())

  @@index([tenantId])
  @@index([accountId])
}

enum PaymentStatus {
  SETTLED
  FAILED
}

// Single-use nonces for admin signed-request auth (adminSignatureAuth replay
// guard). Short-lived (bounded by the request timestamp skew window); expired
// rows are swept opportunistically. See
// medialane-core/docs/specs/2026-06-22-portal-admin-signed-request-auth-design.md.
model AdminAuthNonce {
  nonce     String   @id
  expiresAt DateTime

  @@index([expiresAt])
}

/// IP-Sponsorship has no factory and mints nothing itself — offers/bids/
/// licenses are NOT Collection/Token rows (there is nothing to mint on
/// IPSponsorship; the receipt NFT, if any, is minted separately on a
/// dedicated IPGenesis instance and tracked only via licenseNftTokenId
/// below, never as its own Token row). Populated by a dedicated poller
/// (src/mirror/sponsorshipPoller.ts), not the main Collection-factory mirror
/// loop.
model SponsorshipOffer {
  id                  String               @id @default(cuid())
  chain               Chain                @default(STARKNET)
  sponsorshipContract String
  offerId             String
  author              String
  nftContract         String
  tokenId             String
  minAmount           String
  duration            BigInt
  paymentToken        String
  licenseTermsUri     String
  transferable        Boolean
  specificSponsor     String?
  open                Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  bids                SponsorshipBid[]
  licenses            SponsorshipLicense[]

  @@unique([chain, sponsorshipContract, offerId])
  @@index([chain, nftContract])
  @@index([chain, author])
}

model SponsorshipBid {
  id                  String           @id @default(cuid())
  chain               Chain            @default(STARKNET)
  sponsorshipContract String
  offerId             String
  sponsor             String
  amount              String
  status              SponsorshipBidStatus @default(ACTIVE)
  updatedAt           DateTime         @updatedAt
  offer               SponsorshipOffer @relation(fields: [chain, sponsorshipContract, offerId], references: [chain, sponsorshipContract, offerId])

  @@unique([chain, sponsorshipContract, offerId, sponsor])
}

enum SponsorshipBidStatus {
  ACTIVE
  RETRACTED
  ACCEPTED
}

model SponsorshipLicense {
  id                   String           @id @default(cuid())
  chain                Chain            @default(STARKNET)
  sponsorshipContract  String
  licenseId            String
  offerId              String
  sponsor              String
  transferable         Boolean
  expiresAt            BigInt
  /// Non-authoritative receipt — is_license_valid() on IPSponsorship is the
  /// sole authority for gating/perks regardless of these two fields.
  licenseNftContract   String?
  licenseNftTokenId    String?
  createdAt            DateTime         @default(now())
  offer                SponsorshipOffer @relation(fields: [chain, sponsorshipContract, offerId], references: [chain, sponsorshipContract, offerId])

  @@unique([chain, sponsorshipContract, licenseId])
}
