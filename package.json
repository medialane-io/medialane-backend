{
  "name": "medialane-backend",
  "version": "0.1.1",
  "description": "Medialane off-chain service layer for Starknet",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "reset-cursor": "bun run scripts/resetCursor.ts",
    "seed-rewards": "bun run src/scripts/seed-rewards.ts",
    "compute-rewards": "bun run src/scripts/compute-rewards.ts",
    "verify-accounts": "bun run src/scripts/verify-account-model.ts",
    "prod:verify": "railway run --service Postgres bash -c 'DATABASE_URL=\"$DATABASE_PUBLIC_URL\" bun run verify-accounts'",
    "prod:migrate-status": "railway run --service Postgres bash -c 'DATABASE_URL=\"$DATABASE_PUBLIC_URL\" bunx prisma migrate status'",
    "test": "bun test src"
  },
  "dependencies": {
    "@clerk/backend": "^3.12.0",
    "@hono/node-server": "^2.0.11",
    "@hono/zod-validator": "^0.7.6",
    "@medialane/sdk": "0.71.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@prisma/client": "^6.19.3",
    "@scure/base": "^2.2.0",
    "@stellar/stellar-sdk": "^16.1.0",
    "hono": "^4.12.31",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pinata": "^2.5.6",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "starknet": "^6.24.1",
    "viem": "^2.55.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^7.0.12",
    "prisma": "^6.19.3",
    "typescript": "^5.9.3"
  }
}