{
  "name": "medialane-backend",
  "version": "0.1.1",
  "description": "Medialane off-chain service layer for Starknet",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "reset-cursor": "bun run scripts/resetCursor.ts",
    "seed-rewards": "bun run src/scripts/seed-rewards.ts",
    "seed-app-tenants": "bun run src/scripts/seed-app-tenants.ts",
    "backfill-tenant-to-account": "bun run src/scripts/backfill-tenant-to-account.ts",
    "compute-rewards": "bun run src/scripts/compute-rewards.ts",
    "verify-accounts": "bun run src/scripts/verify-account-model.ts",
    "prod:verify": "railway run --service Postgres bash -c 'DATABASE_URL=\"$DATABASE_PUBLIC_URL\" bun run verify-accounts'",
    "prod:migrate-status": "railway run --service Postgres bash -c 'DATABASE_URL=\"$DATABASE_PUBLIC_URL\" bunx prisma migrate status'",
    "test": "bun test src"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@medialane/sdk": "0.65.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@prisma/client": "^5.22.0",
    "@scure/base": "^2.2.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "hono": "^4.12.12",
    "ioredis": "^5.3.2",
    "nodemailer": "^8.0.5",
    "pinata": "^2.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "starknet": "^6.11.0",
    "viem": "^2.54.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0"
  }
}